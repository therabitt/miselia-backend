# ═══════════════════════════════════════════════════════════════════════════
# File    : .env.example
# Desc    : Template environment variables — copy ke .env dan isi valuenya.
#           JANGAN commit .env ke git — hanya .env.example yang di-commit.
# Step    : STEP 3 — Backend Setup
# Ref     : Blueprint Appendix A
# ═══════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/miselia_dev
DATABASE_URL_TEST=postgresql://postgres:password@localhost:5432/miselia_test
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── OpenAI ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096

# ── AI Fallback — Decision #23 ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=AIza...
AI_FALLBACK_ENABLED=true

# ── Paper APIs ────────────────────────────────────────────────────────────
SEMANTIC_SCHOLAR_API_KEY=your-ss-api-key
OPENALEX_EMAIL=dev@miselia.id

# ── Payment — Midtrans ────────────────────────────────────────────────────
MIDTRANS_SERVER_KEY=SB-Mid-server-...
MIDTRANS_CLIENT_KEY=SB-Mid-client-...
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_WEBHOOK_SECRET=your-webhook-secret

# ── Storage — Cloudflare R2 ───────────────────────────────────────────────
CLOUDFLARE_R2_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_ACCESS_KEY=your-access-key
CLOUDFLARE_R2_SECRET_KEY=your-secret-key
CLOUDFLARE_R2_BUCKET_NAME=miselia-outputs

# ── Email — Resend ────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@miselia.id

# ── App ───────────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=generate-a-long-random-secret-key-here
FRONTEND_URL=http://localhost:3000
# Format: IP1,IP2,IP3 (tanpa spasi)
ADMIN_IP_WHITELIST=127.0.0.1

# ── Monitoring — Sentry ───────────────────────────────────────────────────
SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX

# ── Analytics — PostHog ──────────────────────────────────────────────────
POSTHOG_PROJECT_API_KEY=phc_...
POSTHOG_HOST=https://app.posthog.com
